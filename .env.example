# =============================================================================
# Rulebook RAG Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# OpenAI API (REQUIRED)
# -----------------------------------------------------------------------------
# Get your API key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxx

# Optional: Override default models
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_CHAT_MODEL=gpt-4o

# -----------------------------------------------------------------------------
# PostgreSQL Database (REQUIRED for persistent storage)
# -----------------------------------------------------------------------------
# Full connection URL (takes precedence if set)
DATABASE_URL=postgresql://rulebook:rulebook@localhost:5432/rulebook_rag

# Individual connection parameters (used by Docker Compose)
POSTGRES_USER=rulebook
POSTGRES_PASSWORD=changeme
POSTGRES_DB=rulebook_rag
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# Vector Index Settings (optional)
# -----------------------------------------------------------------------------
# Embedding dimensions - must match your embedding model output
# text-embedding-3-small: 1536 (default)
# text-embedding-3-large: 3072
# EMBEDDING_DIMENSIONS=1536

# Default number of chunks to retrieve for QA
# DEFAULT_TOP_K=5

# -----------------------------------------------------------------------------
# Chunking Settings (optional)
# -----------------------------------------------------------------------------
# Maximum tokens per chunk
# CHUNK_MAX_TOKENS=512

# Minimum tokens before breaking on heading
# CHUNK_MIN_TOKENS=50

# Token overlap between consecutive chunks
# CHUNK_OVERLAP_TOKENS=50

# -----------------------------------------------------------------------------
# Reducto API (optional - for PDF parsing)
# -----------------------------------------------------------------------------
# Get your API key at: https://reducto.ai
# REDUCTO_API_KEY=your-reducto-api-key-here

# -----------------------------------------------------------------------------
# pgAdmin (optional - database management UI)
# -----------------------------------------------------------------------------
# Access at http://localhost:5050 after running docker-compose --profile tools up
PGADMIN_EMAIL=admin@local.dev
PGADMIN_PASSWORD=changeme
PGADMIN_PORT=5050

# -----------------------------------------------------------------------------
# Logging & Debug (optional)
# -----------------------------------------------------------------------------
# LOG_LEVEL=INFO
# DEBUG=0
